# ============================================
# Backend Environment Variables
# ============================================

# Server Configuration
PORT=5001

# AI Provider Configuration
# Default provider: openrouter (OpenAI-compatible API via OpenRouter)
# Use openrouter when OPENAI_API_KEY is an OpenRouter key (sk-or-v1-…)
AI_PROVIDER=openrouter

# Default OpenRouter model (provider/model format)
OPENROUTER_MODEL=openai/gpt-oss-120b

# AI Model Selection (legacy providers; used when AI_PROVIDER is not openrouter)
OPENAI_MODEL=gpt-4o-mini
GROQ_MODEL=llama-3.1-8b-instant
MISTRAL_MODEL=mistral-large-latest
GOOGLE_MODEL=gemini-2.5-flash

# OpenRouter API key (stored as OPENAI_API_KEY for backward compatibility)
OPENAI_API_KEY=your-openrouter-api-key

# Optional: other provider keys when AI_PROVIDER is not openrouter
GROQ_API_KEY=your-groq-api-key
MISTRAL_API_KEY=your-mistral-api-key
GOOGLE_GENERATIVE_AI_API_KEY=your-google-gemini-api-key

# Optional OpenRouter attribution headers
# OPENROUTER_HTTP_REFERER=https://empire-compass.tib.eu
# OPENROUTER_APP_TITLE=EmpiRE Compass

# Environment
NODE_ENV=development
